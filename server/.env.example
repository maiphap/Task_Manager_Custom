# Server Configuration
PORT=3001

# MongoDB Connection
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=AppName
MONGO_URI=mongodb+srv://username:password@your-cluster.mongodb.net/?appName=YourApp

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
TOKEN_EXPIRE_TIME=1h

# Google OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_from_console.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_from_console

# Email Service Configuration (Nodemailer)
# Gmail/SMTP example
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
CLIENT_URL=https://task-manager-custom-sand.vercel.app
